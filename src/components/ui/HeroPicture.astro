---
import type { ImageMetadata } from "astro";
import { getImage } from "astro:assets";

interface Props {
    mobileImg: ImageMetadata;
    desktopImg: ImageMetadata;
    alt: string;
    className?: string;
}

const { mobileImg, desktopImg, alt, className } = Astro.props as Props;

const desktopAvif = await getImage({ src: desktopImg, format: "avif" });
const desktopWebp = await getImage({ src: desktopImg, format: "webp" });
const mobileAvif = await getImage({ src: mobileImg, format: "avif" });
const mobileWebp = await getImage({ src: mobileImg, format: "webp" });

const classProp = className ? className : "";
---

<picture>
    <source media="(max-width: 1023px)" srcset={ mobileAvif.src } type="image/avif" />
    <source media="(max-width: 1023px)" srcset={ mobileWebp.src } type="image/webp" />
    <source media="(min-width: 1023px)" srcset={ desktopAvif.src } type="image/avif" />
    <source media="(min-width: 1023px)" srcset={ desktopWebp.src } type="image/webp" />
    <img
        src={ desktopImg.src }
        alt={ alt }
        class={ classProp }
        loading="eager"
        decoding="async"
    />
</picture>
