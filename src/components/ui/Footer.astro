---
const currentYear = new Date().getFullYear();

const BarNav = [
    {
        anchorText: "Servicios",
        url: "/servicios"
    },
    // {
    //     anchorText: "Energía solar",
    //     url: "/energia-solar"
    // },
    {
        anchorText: "Obras realizadas",
        url: "/obras-realizadas"
    },
    {
        anchorText: "Nosotros",
        url: "/nosotros"
    },
    {
        anchorText: "Contacto",
        url: "/contacto"
    }
];
---
<footer class="bg-black pt-24 pb-8">
    <div class="w-10/12 mx-auto flex flex-col lg:flex-row gap-8 pb-8">
        <div class="w-1/4">

        </div>
        <div class="w-1/4">
            <h3 class="text-white font-bold mb-8">Empresa</h3>
            <ul class="text-white">
                {
                    BarNav.map( link => (
                        <li><a href={ link.url }>{ link.anchorText }</a></li>
                    ))
                }
            </ul>
        </div>
        <div class="w-1/4">
            <h3 class="text-white font-bold mb-8">Soporte</h3>
        </div>
        <div class="w-1/4">
            <h3 class="text-white font-bold mb-8">Políticas</h3>
            <ul class="text-white">
                <li><a href="/politica-privacidad">Políticas de privacidad</a></li>
            </ul>
        </div>
    </div>
    <div class="w-10/12 mx-auto border border-t-white pt-8">
        <p class="text-xs text-center text-white">© { currentYear } MO Diseño y Arquitectura<br />
        todos los derechos reservados</p>
    </div>
</footer>