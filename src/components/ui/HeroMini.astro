---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BTNWhatsapp from '../botones/BTNWhatsapp.astro';

interface Props {
    section: string;
    title: string;
    copy: string;
    cta?: string;
    bgImage?: string | ImageMetadata;
    transitionName?: string;
    textColor?: string;
    colorLayer?: boolean;
}

const { section, title, copy, cta, bgImage, transitionName, textColor="text-inherit", colorLayer=false } = Astro.props;

const transitionNameValue = transitionName || `${title}-image`;
const isLocalImage = bgImage && typeof bgImage === 'object';
---
<header class="pb-80 lg:py-51 mx-4 md:mx-8 rounded-b-lg relative overflow-hidden">
    <figure class:list={[
        "absolute bg-gray-300 w-full h-full top-0 left-0 z-0",
        colorLayer ? "before:content-[''] before:absolute before:z-10 before:w-full before:h-full before:top-0 before:left-0 before:bg-linear-to-r before:from-(--color-2) before:from-10% before:to-(--color-2)/0" : ""
    ]}>
        {
            isLocalImage ? (
                <Image
                    transition:name={ transitionNameValue }
                    src={ bgImage }
                    alt={ title }
                    width={ 1920 }
                    height={ 1080 }
                    class="w-full h-full object-cover object-[65%] relative z-0"
                    loading="eager"
                    decoding="async"
                    fetchpriority="high"
                    sizes="100vw"
                />
            ) : bgImage ? (
                <img
                    transition:name={ transitionNameValue }
                    src={ bgImage }
                    alt={ title }
                    class="w-full h-full object-cover object-[65%] relative z-0"
                    loading="eager"
                    decoding="async"
                    fetchpriority="high"
                />
            ) : null
        }
    </figure>
    <div class="w-full md:w-2/3 lg:w-[33%] ml-0 lg:ml-39 relative z-10 p-8 md:p-12 lg:p-0">
        <p class={`font-light uppercase text-sm md:text-lg mb-2 ${ textColor }`}>{ section }</p>
        <h1 class={`text-2xl md:text-4xl mb-4 font-medium ${ textColor }`}>{ title }</h1>
        <p class:list={[
            `text-lg lg:text-3xl font-light ${ textColor }`,
            cta ? "mb-8" : ""
        ]}>{ copy }</p>
        {
            cta &&
                <BTNWhatsapp 
                    anchor={ cta }
                />
        }
    </div>
</header>