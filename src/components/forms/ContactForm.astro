---
interface Props {
    endpoint?: string;
    class?: string;
}

const { endpoint = "/api/contact", class: className } = Astro.props;
---

<form
    method="POST"
    action="#"
    class:list={["grid grid-cols-1 md:grid-cols-2 gap-8 w-full", className]}
    id="contact-form"
>
    <input
        type="text"
        name="nombre"
        placeholder="Nombre"
        required
        class="bg-(--color-2) p-4 rounded-lg text-lg font-light w-full md:col-span-1"
    />
    <input
        type="text"
        name="apellido"
        placeholder="Apellido"
        required
        class="bg-(--color-2) p-4 rounded-lg text-lg font-light w-full md:col-span-1"
    />
    <input
        type="tel"
        name="telefono"
        placeholder="Teléfono"
        required
        class="bg-(--color-2) p-4 rounded-lg text-lg font-light w-full"
    />
    <input
        type="email"
        name="email"
        placeholder="Correo electrónico"
        required
        class="bg-(--color-2) p-4 rounded-lg text-lg font-light w-full"
    />
    <textarea
        name="mensaje"
        placeholder="Mensaje"
        required
        class="bg-(--color-2) p-4 rounded-lg text-lg font-light w-full min-h-35 md:col-span-2"
    ></textarea>
    <button
        type="submit"
        class="btn bg-(--color-1) text-xl md:col-span-2 cursor-pointer"
        id="contact-submit"
    >
        Enviar solicitud de asesoría técnica
    </button>
</form>

<script>
    const form = document.getElementById("contact-form") as HTMLFormElement | null;
    const submitBtn = document.getElementById("contact-submit") as HTMLButtonElement | null;
    const API_URL = "/api/contact";

    if ( !form || !submitBtn ) {
        return;
    }

    form.addEventListener( "submit", async ( e ) => {
        e.preventDefault();

        submitBtn.disabled = true;
        submitBtn.textContent = "Enviando...";

        const formData = new FormData( form );

        try {
            const res = await fetch( API_URL, {
                method: "POST",
                body: formData,
            });

            const data = await res.json();

            if ( data.success ) {
                form.reset();
                alert( data.message );
            } else {
                alert( data.message || "Error al enviar el mensaje." );
            }
        } catch {
            alert( "Error de conexión. Intenta de nuevo." );
        } finally {
            submitBtn.disabled = false;
            submitBtn.textContent = "Enviar solicitud de asesoría técnica";
        }
    });
</script>
