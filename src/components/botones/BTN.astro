---
interface Props {
    anchor: string;
    url: string;
    type?: "primary" | "secondary";
}

const { anchor, url, type="primary" } = Astro.props;
---
<a href={ url } class:list={[
    "btn text-lg md:text-xl block shadow-[0_1px_0_--theme(--color-slate-950/.04),0_1px_2px_--theme(--color-slate-950/.12),inset_0_-2px_0_--theme(--color-slate-950/.04)] hover:shadow-[0_1px_0_--theme(--color-slate-950/.04),0_4px_8px_--theme(--color-slate-950/.12),inset_0_-2px_0_--theme(--color-slate-950/.04)]",
    type === "primary" ? "bg-(--color-1) after:bg-(--color-1)" : "bg-white after:bg-white"
]}>
    { anchor }
</a>