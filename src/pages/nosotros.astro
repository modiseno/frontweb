---
import { Image } from 'astro:assets';
export const prerender = true;

import Layout from "@/layouts/Layout.astro";
import HeroMini from "@/components/ui/HeroMini.astro";
import BTNWhatsapp from "@/components/botones/BTNWhatsapp.astro";

const soluciones = [
    {
        title: "Ejecución de obras industriales y de infraestructura civil.",
        text: "Construcción de bodegas, hangares, plataformas, estructuras metálicas y obras de urbanismo."
    },
    {
        title: "Supervisión técnica y control de calidad.",
        text: "Acompañamiento en campo por profesionales especializados en ingeniería y arquitectura."
    },
    {
        title: "Gestión integral de contratistas y recursos.",
        text: "Coordinamos personal, materiales y procesos para asegurar eficiencia y cumplimiento."
    },
    {
        title: "Planeación y control de cronogramas.",
        text: "Seguimiento continuo al avance de obra, optimizando tiempos y recursos."
    },
    {
        title: "Seguridad industrial y control ambiental.",
        text: "Cumplimiento estricto de normas técnicas y protocolos de seguridad en todos los frentes de trabajo."
    }
];

const procesos = [
    {
        title: "Diagnóstico y planificación técnica y financiera",
        text: "Levantamiento de requerimientos, presupuesto y alcance, diseño de cronogramas y definición de recursos."
    },
    {
        title: "Ejecución y supervisión de obra",
        text: "Control técnico permanente y coordinación de equipos en campo."
    },
    {
        title: "Gestión de calidad y seguridad",
        text: "Aplicación de protocolos técnicos y ambientales durante toda la obra."
    },
    {
        title: "Entrega final y soporte postproyecto",
        text: "Revisión final, documentación técnica y acompañamiento al cliente."
    }
];

const beneficios = [
    "Cumplimiento garantizado en plazos y estándares técnicos.",
    "Coordinación integral que evita sobrecostos y retrasos.",
    "Supervisión constante en todas las etapas del proyecto.",
    "Experiencia comprobada en obras de alta complejidad."
];

import heroBg from "@/assets/nosotros-mo-diseno-arq.jpg";
import Procesos from "@/assets/mo-diseno-arquitectura-energia-solar.jpg";

---

<Layout
    title="Construcción y obra civil de principio a fin"
    description="Nuestros servicios están dirigidos a empresas, aerolíneas, operadores logísticos, desarrolladores inmobiliarios y entidades privadas o públicas que requieren soluciones de construcción confiables, con un alto nivel de cumplimiento y estándares de calidad."
>
    <HeroMini 
        section="Nosotros"
        title="Construcción, Obra Civil y Supervisión de Proyectos"
        copy="Ejecución integral de obras residenciales, industriales, comerciales y de infraestructura civil, con control técnico y acompañamiento constante para garantizar calidad, seguridad y cumplimiento."
        cta="Quiero hablar con ustedes"
        bgImage={ heroBg.src }
    />
    <section class="pt-24 pb-16 w-8/12 mx-auto">
        <div class="grid grid-cols-2 gap-8 pb-10">
            <p class="text-xl font-light">En MO Diseño y Arquitectura desarrollamos proyectos de construcción y obra civil de principio a fin, abarcando desde la planeación hasta la entrega final. Contamos con un equipo técnico y operativo especializado en la ejecución de proyectos residenciales, industriales, comerciales y de infraestructura civil de gran escala.</p>
            <p class="text-xl font-light">Nuestros servicios están dirigidos a empresas, aerolíneas, operadores logísticos, desarrolladores inmobiliarios y entidades privadas o públicas que requieren soluciones de construcción confiables, con un alto nivel de cumplimiento y estándares de calidad.</p>
        </div>
        <p class="w-1/2 mx-auto text-2xl text-center font-light italic">Nos diferenciamos por ofrecer una gestión integral y una supervisión técnica permanente, asegurando que cada fase del proyecto cumpla con los lineamientos estructurales, normativos y de seguridad industrial exigidos en el sector.</p>
    </section>
    <section class="mt-16 mb-16 pt-16 pb-16 bg-[#dde8d8]">
        <div class="w-10/12 mx-auto">
            <h2 class="text-5xl font-bold text-[#555555] text-center mb-12">Principales <strong class="text-black font-bold">soluciones</strong></h2>
            <div class="grid grid-cols-5 gap-8">
                {
                    soluciones.map( ( solucion ) => (
                        <div class="mb-8">
                            <h3 class="text-2xl text-center font-semibold mb-2">{ solucion.title }</h3>
                            <p class="text-xl text-center font-light">{ solucion.text }</p>
                        </div>
                    ) )
                }
            </div>
        </div>
    </section>
    <section class="pt-16 pb-16 w-10/12 mx-auto flex flex-col md:flex-row gap-16">
        <figure class="w-full md:w-1/2 rounded-lg bg-(--color-3)">
            <Image 
                src={ Procesos }
                alt="Procesos de trabajo"
                width={ 600 }
                height={ 400 }
                class="w-full h-full object-cover rounded-lg"
            />
        </figure>
        <div class="w-full md:w-1/2 py-4">
            <h2 class="text-5xl font-bold text-[#555555] mb-12">Procesos de <strong class="text-black font-bold">trabajo</strong></h2>
            {
                procesos.map( ( proceso ) => (
                    <div class="mb-8">
                        <h3 class="text-2xl font-semibold mb-2">{ proceso.title }</h3>
                        <p class="text-xl font-light">{ proceso.text }</p>
                    </div>
                ) )
            }
        </div>
    </section>
    <section class="w-10/12 mx-auto pt-16 pb-24">
        <h2 class="text-5xl font-bold text-[#555555] mb-8 w-1/2">Beneficios</h2>
        <div class="flex flex-row gap-8">
            <div class="bg-[#ebe6d2] rounded-lg p-16 flex flex-col items-center w-1/4">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 mb-4" width="1em" height="1em" viewBox="0 0 2048 2048">
                    <path d="M0 0h2048v2048H0z" fill="none" />
                    <path fill="currentColor" d="M832 794L467 429l90-90l275 275l531-531l90 90zm1088 482q1 2 1 29t1 69t0 97t0 111t-1 114t0 102t-1 79t0 43H0v-121q0-47-1-103t0-113t-1-112t0-96t0-70t2-29l238-714l101 102l-205 616h418l128 256h560l128-256h418l-269-809l101-101zm-128 132h-344l-128 256H600l-128-256H128v384h1664z" />
                </svg>
                <p class="text-xl font-light text-center">Cumplimiento garantizado en plazos y estándares técnicos.</p>
            </div>
            <div class="bg-[#ebe6d2] rounded-lg p-16 flex flex-col items-center w-1/4">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 mb-4" width="1em" height="1em" viewBox="0 0 24 24">
                    <path d="M0 0h24v24H0z" fill="none" />
                    <g fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M16.755 2h-9.51c-1.159 0-1.738 0-2.206.163a3.05 3.05 0 0 0-1.881 1.936C3 4.581 3 5.177 3 6.37v14.004c0 .858.985 1.314 1.608.744a.946.946 0 0 1 1.284 0l.483.442a1.657 1.657 0 0 0 2.25 0a1.657 1.657 0 0 1 2.25 0a1.657 1.657 0 0 0 2.25 0a1.657 1.657 0 0 1 2.25 0a1.657 1.657 0 0 0 2.25 0l.483-.442a.946.946 0 0 1 1.284 0c.623.57 1.608.114 1.608-.744V6.37c0-1.193 0-1.79-.158-2.27a3.05 3.05 0 0 0-1.881-1.937C18.493 2 17.914 2 16.755 2Z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="m9.5 10.4l1.429 1.6L14.5 8" />
                        <path stroke-linecap="round" d="M7.5 15.5h9" />
                    </g>
                </svg>
                <p class="text-xl font-light text-center">Coordinación integral que evita sobrecostos y retrasos.</p>
            </div>
            <div class="bg-[#ebe6d2] rounded-lg p-16 flex flex-col items-center w-1/4">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 mb-4" width="1em" height="1em" viewBox="0 0 20 20">
                    <path d="M0 0h20v20H0z" fill="none" />
                    <path fill="currentColor" d="M3 5.5a1 1 0 1 0 0-2a1 1 0 0 0 0 2m3-1a.5.5 0 0 1 .5-.5h11a.5.5 0 0 1 0 1h-11a.5.5 0 0 1-.5-.5m0 5a.5.5 0 0 1 .5-.5h11a.5.5 0 0 1 0 1h-11a.5.5 0 0 1-.5-.5m4.022 5.5q.047-.516.185-1H6.5a.5.5 0 0 0 0 1zM4 14.5a1 1 0 1 1-2 0a1 1 0 0 1 2 0m-1-4a1 1 0 1 0 0-2a1 1 0 0 0 0 2m17 5a4.5 4.5 0 1 1-9 0a4.5 4.5 0 0 1 9 0m-5.5.793l-.646-.647a.5.5 0 0 0-.708.708l1 1a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708z" />
                </svg>
                <p class="text-xl font-light text-center">Supervisión constante en todas las etapas del proyecto.</p>
            </div>
            <div class="bg-[#ebe6d2] rounded-lg p-16 flex flex-col items-center w-1/4">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 mb-4" width="1em" height="1em" viewBox="0 0 16 16">
                    <path d="M0 0h16v16H0z" fill="none" />
                    <path fill="currentColor" d="M8 2.57a.5.5 0 0 1 .489.399l.389 1.89l1.92-.214l.087-.002a.5.5 0 0 1 .287.884l-.072.05l-1.68.953l.797 1.76l.028.083a.5.5 0 0 1-.19.528a.5.5 0 0 1-.56.017l-.07-.052l-1.43-1.3l-1.43 1.3a.5.5 0 0 1-.792-.576l.796-1.76l-1.68-.954a.501.501 0 0 1 .302-.932l1.92.214l.39-1.89l.025-.084a.5.5 0 0 1 .465-.315z" />
                    <path fill="currentColor" fill-rule="evenodd" d="M8 0a6.005 6.005 0 0 1 5.127 9.12l1.7 2.55a1 1 0 0 1-.84 1.554l-2.34-.02l-.88 2.17a1.002 1.002 0 0 1-1.76.18l-1.01-1.51l-1.01 1.52a1 1 0 0 1-1.758-.18l-.88-2.17l-2.34.02a.999.999 0 0 1-.84-1.554l1.7-2.56A6.005 6.005 0 0 1 8 .01zM2 12.2l2.68-.023a.5.5 0 0 1 .469.311l1.01 2.49l2-3.01q-.08.004-.161.005c-1.79 0-3.4-.787-4.5-2.03l-1.5 2.26zm10.5-2.26a5.96 5.96 0 0 1-3 1.84l-.893 1.33l1.24 1.85l1.01-2.49a.5.5 0 0 1 .468-.312l2.68.024l-1.5-2.25zM8 .97c-2.76 0-5 2.24-5 5s2.24 5 5 5s5-2.24 5-5s-2.24-5-5-5" clip-rule="evenodd" />
                </svg>
                <p class="text-xl font-light text-center">Experiencia comprobada en obras de alta complejidad.</p>
            </div>
        </div>
        <div class="flex justify-center pt-16">
            <BTNWhatsapp 
                anchor="Quiero una asesoría"
            />
        </div>
    </section>
</Layout>