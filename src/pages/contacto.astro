---
export const prerender = true;
import { siteContact } from "@/consts/site-contact"

import Layout from "@/layouts/Layout.astro";

import HeroMini from "@/components/ui/HeroMini.astro";
import ContactForm from "@/components/forms/ContactForm.astro";
import ContactoBG from "@/assets/mo-diseno-arquitectura-contacto.jpg";

---

<Layout
    title="Contacto MO Diseño y Arquitectura"
    description="Ya sea una obra industrial, una remodelación, un plan de mantenimiento o una solución especializada para tu empresa, en MO Diseño y Arquitectura estamos listos para ayudarte."
>
    <HeroMini 
        section="Contacto"
        title="Hablemos de tu próximo proyecto"
        copy="Ya sea una obra industrial, una remodelación, un plan de mantenimiento o una solución especializada para tu empresa, en MO Diseño y Arquitectura estamos listos para ayudarte."
        bgImage={ ContactoBG }
    />

    <section class="pt-24 pb-16 w-10/12 mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-(--color-2) rounded-lg p-8 flex flex-raw gap-4 justify-center items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-18 h-18" width="1em" height="1em" viewBox="0 0 36 36">
                <path d="M0 0h36v36H0z" fill="none" />
                <path fill="currentColor" d="M32 6H4a2 2 0 0 0-2 2v20a2 2 0 0 0 2 2h28a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2m-1.54 22H5.66l7-7.24l-1.44-1.39L4 26.84V9.52l12.43 12.37a2 2 0 0 0 2.82 0L32 9.21v17.5l-7.36-7.36l-1.41 1.41ZM5.31 8h25.07L17.84 20.47Z" class="clr-i-outline clr-i-outline-path-1" />
                <path fill="none" d="M0 0h36v36H0z" />
            </svg>
            <p class="text-xl font-light">
                <span class="text-lg font-medium block">Correo electrónico</span>
                { siteContact.email }
            </p>
        </div>
        <div class="bg-(--color-2) rounded-lg p-8 flex flex-raw gap-4 justify-center items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-18 h-18" width="1em" height="1em" viewBox="0 0 16 16">
                <path d="M0 0h16v16H0z" fill="none" />
                <g fill="currentColor">
                    <path d="M11 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zM5 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2z" />
                    <path d="M8 14a1 1 0 1 0 0-2a1 1 0 0 0 0 2" />
                </g>
            </svg>
            <p class="text-xl font-light">
                <span class="text-lg font-medium block">Teléfono</span>
                { siteContact.phone }
            </p>
        </div>
        <div class="bg-(--color-2) rounded-lg p-8 flex flex-raw gap-4 justify-center items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-18 h-18" width="1em" height="1em" viewBox="0 0 24 24">
                <path d="M0 0h24v24H0z" fill="none" />
                <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
                    <circle cx="12" cy="10" r="3" />
                    <path d="M12 2a8 8 0 0 0-8 8c0 1.892.402 3.13 1.5 4.5L12 22l6.5-7.5c1.098-1.37 1.5-2.608 1.5-4.5a8 8 0 0 0-8-8" />
                </g>
            </svg>
            <p class="text-xl font-light">
                <span class="text-lg font-medium block">Dirección</span>
                { siteContact.address }, { siteContact.city }
            </p>
        </div>
    </section>
    <section class="pt-16 pb-24 w-10/12 mx-auto grid grid-cols-1 md:grid-cols-2 gap-16">
        <div>
            <h2 class="text-3xl font-bold mb-6">Solicita asesoría técnica</h2>
            <p class="text-xl font-light mb-6">Completa el formulario y uno de nuestros profesionales revisará tu solicitud para brindarte una respuesta oportuna.</p>
            <p class="text-xl font-light mb-4">Nuestro equipo está preparado para acompañarte en proyectos de:</p>
            <ul class="list-disc list-inside text-xl font-light space-y-1">
                <li>Construcción y obra civil</li>
                <li>Remodelaciones y adecuaciones</li>
                <li>Mantenimiento residencial, industrial y corporativo</li>
                <li>Diseño arquitectónico</li>
                <li>Soluciones de energía solar</li>
            </ul>
        </div>
        <div>
            <ContactForm />
        </div>
    </section>
</Layout>